{
  "name": "quote-desk-next-mvp",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "npm --workspace apps/web run dev",
    "build": "npm --workspace apps/web run build",
    "preview": "npm --workspace apps/web run preview",
    "audit:hygiene": "node scripts/check-worktree-hygiene.mjs",
    "audit:hygiene:strict": "node scripts/check-worktree-hygiene.mjs --strict",
    "audit:modules": "node scripts/check-module-boundaries.mjs",
    "audit:core": "node scripts/check-core-guardian.mjs",
    "audit:secrets": "node scripts/check-secret-surface.mjs",
    "guardian:brands": "node scripts/maintenance/ensure-tecalliance-brand-records.mjs",
    "guardian:brands:apply": "node scripts/maintenance/ensure-tecalliance-brand-records.mjs --apply",
    "clean:worktree": "node scripts/clean-worktree-artifacts.mjs",
    "db:migrate:staged": "node scripts/ops/apply-staged-supabase-migrations.mjs",
    "netlify:ensure-link": "node scripts/ops/ensure-netlify-linked.mjs",
    "predeploy:verify": "npm run netlify:ensure-link && npm run guardian:brands:apply && npm run build && npm run audit:core && npm run audit:secrets && npm run audit:hygiene:strict",
    "deploy:status": "node scripts/ops/check-netlify-deploy-state.mjs",
    "ship": "node scripts/ship-staged-to-production.mjs",
    "ship:dry-run": "node scripts/ship-staged-to-production.mjs --dry-run"
  },
  "devDependencies": {
    "yaml": "^2.9.0"
  },
  "dependencies": {
    "jimp": "^1.6.1",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0"
  }
}
